<%- include('../partials/head', { title: 'Your Tasks' }) %>
<%- include('../partials/nav', { user }) %>
<%- include('../partials/flash', { messages }) %>

<main class="mx-auto max-w-5xl px-4 py-10">
  <div class="flex flex-col gap-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold">Your tasks</h1>
        <p class="mt-1 text-sm text-slate-600">Only you can see what you create.</p>
      </div>

      <form action="/tasks" method="post" class="flex w-full max-w-md gap-2">
        <input name="title" type="text" required class="w-full rounded-xl border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-900" placeholder="Add a new task..." />
        <button class="shrink-0 rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Add</button>
      </form>
    </div>

    <div class="rounded-2xl border bg-white shadow-sm">
      <div class="divide-y">
        <% if (!tasks || tasks.length === 0) { %>
          <div class="p-6 text-sm text-slate-600">No tasks yet. Add one above.</div>
        <% } %>

        <% (tasks || []).forEach(task => { %>
          <div class="flex items-center justify-between gap-3 p-4">
            <div class="flex items-center gap-3">
              <form action="/tasks/<%= task._id %>/toggle" method="post">
                <button class="inline-flex h-9 w-9 items-center justify-center rounded-xl border hover:bg-slate-50" aria-label="Toggle status">
                  <% if (task.status === 'completed') { %>
                    <span class="text-emerald-600">✓</span>
                  <% } else { %>
                    <span class="text-slate-400">○</span>
                  <% } %>
                </button>
              </form>
              <div>
                <div class="text-sm font-medium <%= task.status === 'completed' ? 'line-through text-slate-400' : '' %>"><%= task.title %></div>
                <div class="text-xs text-slate-500">Status: <%= task.status %></div>
              </div>
            </div>
            <form action="/tasks/<%= task._id %>/delete" method="post">
              <button class="rounded-xl border px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">Delete</button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/foot') %>
