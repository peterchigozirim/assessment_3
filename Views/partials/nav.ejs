<nav class="border-b bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/tasks" class="text-sm font-semibold tracking-tight">Todo</a>

    <div class="flex items-center gap-3">
      <% if (user) { %>
        <span class="hidden text-sm text-slate-600 sm:inline">Signed in as <span class="font-medium"><%= user.name || user.email %></span></span>
        <form action="/logout" method="post">
          <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-800">Logout</button>
        </form>
      <% } else { %>
        <a href="/login" class="text-sm text-slate-700 hover:text-slate-900">Login</a>
        <a href="/register" class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-800">Register</a>
      <% } %>
    </div>
  </div>
</nav>
